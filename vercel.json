{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "vite --host 0.0.0.0",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://preproute-backend.vercel.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}